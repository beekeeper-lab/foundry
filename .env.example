# Foundry environment template
#
# Copy this file to `.env` (which is gitignored) and fill in the keys you need.
# The media skills (generate-image, generate-audio) discover this file via
# `_media_lib.env.load_env`, walking cwd → parents → $HOME and loading the
# first `.env` found. Existing process environment values always win, so a
# CI secret or shell export beats a stale checked-in `.env`.
#
# Only set the keys for providers you actually use — missing keys are fine
# until a run hits a code path that needs one (the skills exit with a clear
# message).

# generate-image, default provider (Gemini "Nanobanana" family).
GEMINI_API_KEY=

# generate-image, OpenAI gpt-image family. Required when an IMAGE-PLAN.md's
# **Generator:** frontmatter resolves to OpenAI (any value containing
# "openai" or "gpt-image", case-insensitive).
OPENAI_API_KEY=

# generate-audio (ElevenLabs). Required for every real run; --dry-run does
# not consult this. ElevenLabs Pro is 500K credits/month at $100, billed
# at 1 credit per character for `eleven_multilingual_v2` — every audio run
# prints chars-sent = credits-spent so spend stays visible.
ELEVENLABS_API_KEY=
