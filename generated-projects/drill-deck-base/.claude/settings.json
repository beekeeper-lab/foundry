{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "branch=$(git branch --show-current 2>/dev/null); if [ \"$branch\" = \"main\" ] || [ \"$branch\" = \"master\" ] || [ \"$branch\" = \"test\" ] || [ \"$branch\" = \"prod\" ]; then echo 'BLOCKED: Cannot edit files on a protected branch ($branch). Create a feature branch first.'; exit 1; fi"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/validate-task-inputs.py"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/vdd-gate.py"
          }
        ]
      },
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "branch=$(git branch --show-current 2>/dev/null); if [ -n \"$branch\" ] && ! echo \"$branch\" | grep -qE '^(feature|fix|bean|hotfix|chore)/[a-z0-9-]+$'; then echo \"WARNING: Branch '$branch' does not follow naming convention (feature|fix|bean|hotfix|chore)/<name>.\"; fi"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/handoff-reminder.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/telemetry-stamp.py"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/format-on-save.py"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "ruff check --quiet . 2>/dev/null || echo 'WARNING: Lint issues detected. Run ruff check --fix before committing.'"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "git diff --name-only 2>/dev/null | xargs grep -lE '(?i)(api[_-]?key|secret[_-]?key|password\\s*=|token\\s*=|BEGIN (RSA |EC )?PRIVATE KEY)' 2>/dev/null && echo 'WARNING: Potential secrets detected in changed files.' || true"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/session-start-context.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/stop-quality-reminder.py"
          }
        ]
      }
    ]
  }
}
